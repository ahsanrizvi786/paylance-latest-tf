.w-checkbox {
  margin-bottom: 5px;
  padding-left: 20px;
  display: block;
}

.w-checkbox:before {
  content: " ";
  grid-area: 1 / 1 / 2 / 2;
  display: table;
}

.w-checkbox:after {
  content: " ";
  clear: both;
  grid-area: 1 / 1 / 2 / 2;
  display: table;
}

.w-checkbox-input {
  float: left;
  margin: 4px 0 0 -20px;
  line-height: normal;
}

.w-checkbox-input--inputType-custom {
  border: 1px solid #ccc;
  border-radius: 2px;
  width: 12px;
  height: 12px;
}

.w-checkbox-input--inputType-custom.w--redirected-checked {
  background-color: #3898ec;
  background-image: url("../images/custom-checkbox-checkmark.589d534424.svg");
  background-position: 50%;
  background-repeat: no-repeat;
  background-size: cover;
  border-color: #3898ec;
}

.w-checkbox-input--inputType-custom.w--redirected-focus {
  box-shadow: 0 0 3px 1px #3898ec;
}

body {
  background-color: var(--colors--black);
  font-family: var(--font-family--body);
  color: var(--colors--white);
  font-size: var(--_typography---paragraph-03--font-size);
  line-height: var(--_typography---paragraph-03--line-height);
  font-weight: var(--font-weight--normal);
}

h1 {
  margin-top: var(--_perimeter---margin--margin-none);
  margin-bottom: var(--_perimeter---margin--margin-none);
  font-family: var(--font-family--heading);
  color: var(--colors--white);
  font-size: var(--_typography---h1--font-size);
  line-height: var(--_typography---h1--line-height);
  font-weight: var(--font-weight--normal);
  letter-spacing: var(--letter-spacing--letter-spacing-l);
}

h2 {
  margin-top: var(--_perimeter---margin--margin-none);
  margin-bottom: var(--_perimeter---margin--margin-none);
  font-family: var(--font-family--heading);
  color: var(--colors--white);
  font-size: var(--_typography---h2--font-size);
  line-height: var(--_typography---h2--line-height);
  font-weight: var(--font-weight--normal);
  letter-spacing: var(--letter-spacing--letter-spacing-s);
}

h3 {
  margin-top: var(--_perimeter---margin--margin-none);
  margin-bottom: var(--_perimeter---margin--margin-none);
  font-family: var(--font-family--heading);
  color: var(--colors--white);
  font-size: var(--_typography---h3--font-size);
  line-height: var(--_typography---h3--line-height);
  font-weight: var(--font-weight--normal);
  letter-spacing: var(--letter-spacing--letter-spacing-m);
}

h4 {
  margin-top: var(--_perimeter---margin--margin-none);
  margin-bottom: var(--_perimeter---margin--margin-none);
  font-family: var(--font-family--heading);
  color: var(--colors--white);
  font-size: var(--_typography---h4--font-size);
  line-height: var(--_typography---h4--line-height);
  font-weight: var(--font-weight--normal);
  letter-spacing: var(--letter-spacing--letter-spacing-m);
}

h5 {
  margin-top: var(--_perimeter---margin--margin-none);
  margin-bottom: var(--_perimeter---margin--margin-none);
  font-family: var(--font-family--body);
  color: var(--colors--white);
  font-size: var(--_typography---h5--font-size);
  line-height: var(--_typography---h5--line-height);
  font-weight: var(--font-weight--medium);
  letter-spacing: var(--letter-spacing--letter-spacing-m);
}

h6 {
  margin-top: var(--_perimeter---margin--margin-none);
  margin-bottom: var(--_perimeter---margin--margin-none);
  font-family: var(--font-family--body);
  color: var(--colors--white);
  font-size: var(--_typography---h6--font-size);
  line-height: var(--_typography---h6--line-height);
  font-weight: var(--font-weight--medium);
  letter-spacing: var(--letter-spacing--letter-spacing-m);
}

p {
  margin-bottom: var(--_perimeter---margin--margin-none);
}

a {
  color: var(--colors--white);
  text-decoration: none;
}

ul, ol {
  margin-bottom: var(--_perimeter---margin--margin-none);
  padding-left: var(--_perimeter---padding--padding-xxxl);
}

img {
  width: 100%;
  max-width: 100%;
  height: 100%;
  max-height: 100%;
  display: inline-block;
}

blockquote {
  margin-bottom: var(--_perimeter---margin--margin-none);
  padding: var(--_perimeter---padding--padding-m) var(--_perimeter---padding--padding-xxxl);
  border-left: 5px solid var(--colors--white);
}

.utility-page-wrap {
  flex-flow: column;
  justify-content: center;
  align-items: center;
  display: flex;
  position: relative;
}

.utility-page-content {
  z-index: 5;
  width: 100%;
  max-width: 650px;
  margin-bottom: var(--_perimeter---margin--margin-none);
  padding: var(--_perimeter---padding--padding-13xl) var(--_perimeter---padding--padding-xxxl);
  text-align: center;
  flex-direction: column;
  display: flex;
  position: relative;
}

.utility-page-form {
  flex-direction: column;
  align-items: stretch;
  display: flex;
}

.page-wrapper {
  position: relative;
  overflow: clip;
}

.style-guide {
  padding-top: var(--_perimeter---padding--padding-11xl);
  padding-bottom: var(--_perimeter---padding--padding-11xl);
}

.container {
  z-index: 5;
  width: 100%;
  max-width: 1360px;
  padding-right: var(--_perimeter---padding--padding-xxxl);
  padding-left: var(--_perimeter---padding--padding-xxxl);
  margin-left: auto;
  margin-right: auto;
  position: relative;
}

.style-guide-wrap {
  grid-column-gap: var(--_perimeter---gap--gap-6xl);
  grid-row-gap: var(--_perimeter---gap--gap-6xl);
  justify-content: space-between;
  align-items: flex-start;
  display: flex;
}

.style-guide-left {
  flex-flow: column;
  width: 100%;
  max-width: 300px;
  display: flex;
  position: sticky;
  top: 80px;
}

.style-guide-right {
  grid-column-gap: var(--_perimeter---gap--gap-11xl);
  grid-row-gap: var(--_perimeter---gap--gap-11xl);
  flex-flow: column;
  width: 100%;
  max-width: 900px;
  display: flex;
}

.typography {
  grid-column-gap: var(--_perimeter---gap--gap-7xl);
  grid-row-gap: var(--_perimeter---gap--gap-7xl);
  flex-flow: column;
  display: flex;
}

.typography-list {
  grid-column-gap: var(--_perimeter---gap--gap-l);
  grid-row-gap: var(--_perimeter---gap--gap-l);
  flex-flow: column;
  display: flex;
}

.paragraph-01 {
  font-family: var(--font-family--body);
  color: var(--colors--white);
  font-size: var(--_typography---paragraph-01--font-size);
  line-height: var(--_typography---paragraph-01--line-height);
  font-weight: var(--font-weight--medium);
  letter-spacing: var(--letter-spacing--letter-spacing-m);
}

.paragraph-02 {
  font-family: var(--font-family--body);
  color: var(--colors--white);
  font-size: var(--_typography---paragraph-02--font-size);
  line-height: var(--_typography---paragraph-02--line-height);
  font-weight: var(--font-weight--medium);
  letter-spacing: var(--letter-spacing--letter-spacing-m);
}

.paragraph-02.license-link-title {
  text-align: center;
  transition: color .3s;
}

.paragraph-02.license-link-title:hover {
  color: var(--colors--golden);
}

.paragraph-02.numbers-title {
  width: 100%;
  max-width: 144px;
  color: var(--colors--black);
}

.paragraph-02.numbers-title._02 {
  max-width: 70px;
}

.paragraph-02.numbers-title._03 {
  max-width: 128px;
}

.paragraph-02.numbers-title._04 {
  max-width: 120px;
}

.paragraph-02.partner-statistics-title {
  max-width: 160px;
  color: var(--colors--grey);
}

.paragraph-02.trust-statistics-title {
  max-width: 85px;
}

.paragraph-02.testimonial-details {
  color: var(--colors--grey);
}

.paragraph-03 {
  font-family: var(--font-family--body);
  color: var(--colors--white);
  font-size: var(--_typography---paragraph-03--font-size);
  line-height: var(--_typography---paragraph-03--line-height);
  font-weight: var(--font-weight--normal);
  letter-spacing: var(--letter-spacing--letter-spacing-m);
}

.paragraph-03.menu {
  transition: color .3s;
}

.paragraph-03.menu:hover, .paragraph-03.menu.w--current {
  color: var(--colors--golden);
}

.paragraph-03.copyright-text {
  color: var(--colors--grey);
}

.paragraph-03.subtitle-center {
  color: var(--colors--grey);
  text-align: center;
}

.paragraph-03.pricing-features-subtitle {
  color: var(--colors--grey);
}

.paragraph-03.pass-subtitle {
  margin-bottom: var(--_perimeter---margin--margin-none);
  color: var(--colors--grey);
  text-align: center;
}

.paragraph-03.statistics-title {
  width: 100%;
  max-width: 100px;
}

.paragraph-03.statistics-title.large {
  max-width: 150px;
}

.paragraph-03.partner-tagline, .paragraph-03.team-subtitle, .paragraph-03.tagline {
  color: var(--colors--grey);
}

.paragraph-03.answer {
  width: 90%;
  padding-top: var(--_perimeter---padding--padding-m);
  color: var(--colors--grey);
}

.paragraph-03.credibility-details {
  padding-top: var(--_perimeter---padding--padding-xxl);
  color: var(--colors--light-grey);
  text-align: center;
}

.paragraph-03.author-tagline {
  color: var(--colors--light-grey);
}

.paragraph-03.login-social-title {
  color: var(--colors--black);
  font-weight: var(--font-weight--medium);
}

.paragraph-03.login-divider-title {
  color: var(--colors--grey);
  text-align: center;
  flex: none;
}

.paragraph-03.blog-subtitle {
  color: var(--colors--grey);
}

.caption {
  font-family: var(--font-family--body);
  color: var(--colors--white);
  font-size: var(--_typography---caption--font-size);
  line-height: var(--_typography---caption--line-height);
  font-weight: var(--font-weight--normal);
}

.caption.checkbox-title {
  margin-bottom: var(--_perimeter---margin--margin-none);
  margin-left: var(--_perimeter---gap--gap-s);
  color: var(--colors--grey);
}

.caption.login-page-link {
  color: var(--colors--golden);
  transition: color .3s;
}

.caption.login-page-link:hover {
  color: var(--colors--white);
}

.caption.login-bottom-title {
  color: var(--colors--grey);
  text-align: center;
}

.caption.menu-link {
  color: var(--colors--grey);
  transition: transform .3s, color .3s;
}

.caption.menu-link:hover {
  color: var(--colors--white);
  transform: translate(10px);
}

.caption.menu-link.w--current {
  color: var(--colors--white);
}

.button-text {
  font-family: var(--font-family--body);
  color: var(--colors--white);
  font-size: var(--_typography---button-text--font-size);
  line-height: var(--_typography---button-text--line-height);
  font-weight: var(--font-weight--medium);
  letter-spacing: var(--letter-spacing--letter-spacing-l);
}

.button-text.color-code {
  color: var(--colors--black);
  text-align: center;
}

.button-text.color-code-white {
  color: var(--colors--white);
  text-align: center;
}

.button-text.button-01-title {
  color: var(--colors--black);
}

.button-text.form-label {
  margin-bottom: var(--_perimeter---margin--margin-none);
}

.button-text.button-02-title, .button-text.contact-text-01, .button-text.contact-text-02 {
  color: var(--colors--black);
}

.tag {
  font-family: var(--font-family--body);
  color: var(--colors--white);
  font-size: var(--_typography---tag-text--font-size);
  line-height: var(--_typography---tag-text--line-height);
  font-weight: var(--font-weight--normal);
  text-transform: uppercase;
}

.tag.pricing-badge {
  color: var(--colors--golden);
}

.typography-info-wrap {
  grid-column-gap: var(--_perimeter---gap--gap-xxxl);
  grid-row-gap: var(--_perimeter---gap--gap-l);
  flex-flow: wrap;
  justify-content: space-between;
  display: flex;
}

.text-grey {
  color: var(--colors--grey);
}

.style-guide-link {
  padding-top: var(--_perimeter---padding--padding-xxxl);
  padding-bottom: var(--_perimeter---padding--padding-xxxl);
  border-right: 2px solid var(--colors--white-lite);
}

.style-guide-link.w--current {
  border-right-color: var(--colors--golden);
}

.h5 {
  font-family: var(--font-family--body);
  color: var(--colors--white);
  font-size: var(--_typography---h5--font-size);
  line-height: var(--_typography---h5--line-height);
  font-weight: var(--font-weight--medium);
  letter-spacing: var(--letter-spacing--letter-spacing-m);
}

.style-guide-divider {
  background-color: var(--colors--white-lite);
  width: 100%;
  height: 1px;
}

.colors {
  grid-column-gap: var(--_perimeter---gap--gap-xxxl);
  grid-row-gap: var(--_perimeter---gap--gap-xxxl);
  grid-template-rows: auto;
  grid-template-columns: 1fr 1fr 1fr;
  grid-auto-columns: 1fr;
  display: grid;
}

.color-list {
  height: 195px;
  padding: var(--_perimeter---padding--padding-xxl);
  border-radius: var(--_border-radius---radius-xxxl);
  background-image: url("../images/698d8042a367420b0e34eb01_Gradient.avif"), linear-gradient(169deg, #e9af03, #fcea4c);
  background-position: 50%, 0 0;
  background-repeat: no-repeat, repeat;
  background-size: cover, auto;
  justify-content: center;
  align-items: center;
  display: flex;
}

.color-list.golden {
  background-color: var(--colors--golden);
  background-image: none;
}

.color-list.gradient {
  background-image: radial-gradient(circle, #ffffffe6 17%, #fbec74 78%);
}

.color-list.grey {
  background-color: var(--colors--grey);
  background-image: none;
}

.color-list.light-grey {
  background-color: var(--colors--light-grey);
  background-image: none;
}

.color-list.white {
  background-color: var(--colors--white);
  background-image: none;
}

.color-list.bg {
  background-color: var(--colors--white-lite);
  background-image: none;
}

.color-list.black {
  border: 1px solid var(--colors--grey);
  background-color: var(--colors--black);
  background-image: none;
}

.footer {
  padding-top: var(--_perimeter---padding--padding-11xl);
  padding-bottom: var(--_perimeter---padding--padding-xxxl);
}

.footer-top-wrap {
  grid-column-gap: var(--_perimeter---gap--gap-7xl);
  grid-row-gap: var(--_perimeter---gap--gap-7xl);
  justify-content: space-between;
  align-items: flex-start;
  display: flex;
}

.footer-brand-logo {
  width: 385px;
  height: auto;
}

.footer-text-wrap {
  grid-column-gap: var(--_perimeter---gap--gap-xxxl);
  grid-row-gap: var(--_perimeter---gap--gap-xxxl);
  flex-flow: column;
  width: 100%;
  max-width: 600px;
  display: flex;
}

.heading-wrap.intro-heading {
  flex: none;
}

.text-golden {
  color: var(--colors--golden);
}

.footer-heading {
  font-family: var(--font-family--heading);
  color: var(--colors--white);
  font-size: var(--_typography---h2--font-size);
  line-height: var(--_typography---h2--line-height);
  font-weight: var(--font-weight--normal);
  letter-spacing: var(--letter-spacing--letter-spacing-s);
}

.footer-main-wrap {
  padding-top: var(--_perimeter---padding--padding-13xl);
  grid-column-gap: var(--_perimeter---gap--gap-8xl);
  grid-row-gap: var(--_perimeter---gap--gap-8xl);
  justify-content: space-between;
  align-items: flex-start;
  display: flex;
}

.footer-left {
  grid-column-gap: var(--_perimeter---gap--gap-5xl);
  grid-row-gap: var(--_perimeter---gap--gap-5xl);
  flex-flow: column;
  width: 100%;
  max-width: 465px;
  display: flex;
}

.footer-details-wrap {
  margin-bottom: var(--_perimeter---padding--padding-xxxs);
  grid-column-gap: var(--_perimeter---gap--gap-l);
  grid-row-gap: var(--_perimeter---gap--gap-l);
  flex-flow: column;
  justify-content: flex-start;
  align-items: flex-start;
  display: flex;
}

.h3 {
  font-family: var(--font-family--heading);
  color: var(--colors--white);
  font-size: var(--_typography---h3--font-size);
  line-height: var(--_typography---h3--line-height);
  font-weight: var(--font-weight--normal);
  letter-spacing: var(--letter-spacing--letter-spacing-m);
}

.h3.insight-title {
  -webkit-text-fill-color: transparent;
  background-image: linear-gradient(-165deg, #f6c81a 4%, #fefb76 15%, #fbcc0d 35%, #fffa7a 71%, #e9af03 93%);
  -webkit-background-clip: text;
  background-clip: text;
}

.h3.insight-title-02 {
  color: var(--colors--grey);
}

.h3.credibility-title {
  font-size: var(--_typography---h4--font-size);
  line-height: var(--_typography---h4--line-height);
  text-align: center;
}

.footer-form-wrap {
  grid-column-gap: var(--_perimeter---gap--gap-s);
  grid-row-gap: var(--_perimeter---gap--gap-s);
  align-items: stretch;
  width: 100%;
  display: flex;
}

.form-block {
  width: 100%;
  margin-bottom: var(--_perimeter---margin--margin-none);
}

.footer-form-input {
  height: 48px;
  margin-bottom: var(--_perimeter---margin--margin-none);
  padding-right: var(--_perimeter---padding--padding-4xl);
  padding-left: var(--_perimeter---padding--padding-4xl);
  border: 1px solid var(--colors--black);
  border-radius: var(--_border-radius---radius-8xl);
  background-color: var(--colors--white-lite);
  color: var(--colors--white);
  font-size: var(--_typography---paragraph-03--font-size);
  line-height: var(--_typography---paragraph-03--line-height);
}

.footer-form-input:focus {
  border-color: var(--colors--golden);
}

.footer-form-input::placeholder {
  color: var(--colors--grey);
  font-size: var(--_typography---paragraph-03--font-size);
