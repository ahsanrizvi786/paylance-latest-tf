    --_perimeter---padding--padding-m: 10px;
    --_perimeter---padding--padding-13xl: 72px;
    --_perimeter---padding--padding-12xl: 60px;
    --_perimeter---padding--padding-11xl: 40px;
    --_perimeter---padding--padding-xxl: 16px;
    --_perimeter---gap--gap-6xl: 20px;
    --_perimeter---gap--gap-none: 0px;
    --_perimeter---gap--gap-11xl: 40px;
    --_perimeter---margin--margin-xl: 28px;
    --_perimeter---gap--gap-7xl: 24px;
    --_perimeter---gap--gap-8xl: 28px;
    --_perimeter---gap--gap-l: 12px;
    --_perimeter---padding--padding-xl: 14px;
    --_perimeter---gap--gap-s: 8px;
    --_perimeter---gap--gap-xxxl: 20px;
    --_perimeter---padding--padding-l: 12px;
