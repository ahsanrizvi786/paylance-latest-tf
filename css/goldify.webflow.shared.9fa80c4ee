:root {
  --colors--black: black;
  --font-family--body: "Inter Display", Arial, sans-serif;
  --colors--white: white;
  --_typography---paragraph-03--font-size: 16px;
  --_typography---paragraph-03--line-height: 24px;
  --font-weight--normal: 400;
  --_perimeter---margin--margin-none: 0px;
  --font-family--heading: "Inter Tight", sans-serif;
  --_typography---h1--font-size: 52px;
  --_typography---h1--line-height: 60px;
  --letter-spacing--letter-spacing-l: -.02em;
  --_typography---h2--font-size: 44px;
  --_typography---h2--line-height: 52px;
  --letter-spacing--letter-spacing-s: -1px;
  --_typography---h3--font-size: 32px;
  --_typography---h3--line-height: 40px;
  --letter-spacing--letter-spacing-m: -.01em;
  --_typography---h4--font-size: 24px;
  --_typography---h4--line-height: 30px;
  --_typography---h5--font-size: 24px;
  --_typography---h5--line-height: 30px;
  --font-weight--medium: 500;
  --_typography---h6--font-size: 20px;
  --_typography---h6--line-height: 28px;
  --_perimeter---padding--padding-xxxl: 20px;
  --_perimeter---padding--padding-m: 10px;
  --_perimeter---padding--padding-13xl: 120px;
  --_perimeter---padding--padding-12xl: 100px;
