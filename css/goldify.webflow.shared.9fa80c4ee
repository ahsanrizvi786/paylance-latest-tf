    --_perimeter---padding--padding-4xl: 20px;
    --_perimeter---padding--padding-xs: 6px;
    --_perimeter---gap--gap-4xl: 20px;
    --_perimeter---margin--margin-s: 16px;
    --_perimeter---gap--gap-m: 10px;
    --_perimeter---gap--gap-xl: 16px;
    --_perimeter---margin--margin-m: 20px;
    --_perimeter---padding--padding-10xl: 28px;
    --_perimeter---padding--padding-6xl: 20px;
    --_perimeter---margin--margin-l: 20px;
    --_perimeter---gap--gap-xs: 6px;
    --_perimeter---padding--padding-15xl: 72px;
    --_perimeter---padding--padding-s: 8px;
    --_perimeter---gap--gap-xxs: 4px;
    --_perimeter---padding--padding-none: 0px;
    --_perimeter---padding--padding-7xl: 20px;
    --_perimeter---gap--gap-10xl: 32px;
    --_perimeter---padding--padding-9xl: 28px;
    --_perimeter---margin--margin-xxxl: 40px;
    --_perimeter---gap--gap-xxl: 16px;
    --_perimeter---margin--margin-xxl: 40px;
    --_perimeter---padding--padding-5xl: 20px;
    --_perimeter---padding--padding-8xl: 24px;
    --_perimeter---padding--padding-xxs: 4px;
    --_perimeter---gap--gap-xxxs: 2px;
    --_perimeter---padding--padding-14xl: 72px;
    --_border-radius---radius-xxxl: 16px;
    --_border-radius---radius-xl: 16px;
    --_border-radius---radius-l: 12px;
